# Google Apps Script Webhook URL (server-side only — NOT exposed to browser)
APPS_SCRIPT_URL=your_google_apps_script_webhook_url_here

# Telegram Bot Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# WhatsApp Float Button
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number_here

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code_here
